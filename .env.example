# NapCat 正向 WebSocket（WebSocket 服务器）
ONEBOT_WS_URL=ws://127.0.0.1:3001
ONEBOT_ACCESS_TOKEN=请填写与NapCat中一致的随机Token

# 只响应这些好友的私聊，多个 QQ 号使用英文逗号分隔；测试阶段先填主账号 QQ 号
ONEBOT_ALLOWED_PRIVATE_USER_IDS=123456789

# 只响应这些群中的 @消息；暂不启用群聊时留空
ONEBOT_ALLOWED_GROUP_IDS=

# 本机 Codex CLI。首次运行前先执行 codex login，并保持该登录账号有效。
CODEX_COMMAND=codex
CODEX_MODEL=gpt-5.6-sol
CODEX_REASONING_EFFORT=medium
CODEX_LIVE_SEARCH=true
CODEX_TIMEOUT_MS=300000
CODEX_MAX_CONCURRENT=2
CODEX_MAX_QUEUE=12

# 可选配置
AI_SYSTEM_PROMPT=你是 QQ 里的 AI 助手。请使用简洁、友善、准确的中文回答。
CONVERSATION_MAX_TURNS=8
CONVERSATION_TTL_MS=86400000
RATE_LIMIT_MAX_REQUESTS=6
RATE_LIMIT_WINDOW_MS=60000
ONEBOT_RECONNECT_INTERVAL_MS=5000
ONEBOT_ACTION_TIMEOUT_MS=10000
